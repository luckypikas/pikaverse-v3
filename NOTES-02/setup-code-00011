* {
  box-sizing: border-box;
}

body {
  margin: 0;

  min-height: 100vh;

  display: flex;
  justify-content: center;
  align-items: center;

  background:
    radial-gradient(circle at top, #2a1840 0%, #090909 60%);

  color: #f5f5f5;

  font-family: Arial, sans-serif;
}

#app {
  width: 100%;
  max-width: 700px;

  padding: 24px;
}

.node-container {
  background: rgba(255, 255, 255, 0.08);

  border: 1px solid rgba(255, 255, 255, 0.12);

  border-radius: 20px;

  padding: 32px;

  backdrop-filter: blur(10px);

  box-shadow:
    0 0 30px rgba(0, 0, 0, 0.5);

  text-align: center;
}

.node-container h1 {
  margin-top: 0;

  color: #f4c542;

  font-size: 2rem;
}

.node-container p {
  line-height: 1.6;

  color: #dddddd;
}

.transitions {
  margin-top: 32px;

  display: flex;
  flex-direction: column;
  gap: 16px;
}

.transitions button {
  padding: 14px 20px;

  border: none;
  border-radius: 12px;

  background:
    linear-gradient(
      135deg,
      #6b3fd4,
      #3d1d75
    );

  color: white;

  font-size: 1rem;

  cursor: pointer;

  transition:
    transform 0.2s ease,
    opacity 0.2s ease;
}

.transitions button:hover {
  transform: translateY(-2px);

  opacity: 0.92;
}
```

