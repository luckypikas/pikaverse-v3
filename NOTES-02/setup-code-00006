# FILE: `runtime/renderer.js`

Create this file and paste this EXACTLY:

```js id="61rsk0"
export function renderNode(node, onTransition) {
  const app = document.getElementById("app");

  app.innerHTML = "";

  const container = document.createElement("div");
  container.className = "node-container";

  const title = document.createElement("h1");
  title.textContent = node.title;

  const content = document.createElement("p");
  content.textContent = node.content;

  container.appendChild(title);
  container.appendChild(content);

  const transitions = document.createElement("div");
  transitions.className = "transitions";

  node.transitions.forEach(transition => {
    const button = document.createElement("button");

    button.textContent = transition.label;

    button.addEventListener("click", () => {
      onTransition(transition.target);
    });

    transitions.appendChild(button);
  });

  container.appendChild(transitions);

  app.appendChild(container);
}
```

