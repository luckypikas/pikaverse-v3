FILE: runtime/router.js

Create this file and paste this EXACTLY:

import { getNodeById } from "./loader.js";

import { setCurrentNode } from "./stateStore.js";

import { renderNode } from "./renderer.js";

export class Router {
  constructor(hunt) {
    this.hunt = hunt;
  }

  goTo(nodeId) {
    const node = getNodeById(this.hunt, nodeId);

    if (!node) {
      throw new Error(`Node not found: ${nodeId}`);
    }

    setCurrentNode(nodeId);

    renderNode(node, nextNodeId => {
      this.goTo(nextNodeId);
    });
  }
}
WHAT THIS FILE DOES

This extracts:

gameplay navigation

from:

runtime orchestration

That is a MASSIVE architecture improvement.

IMPORTANT DESIGN PRINCIPLE

The router now owns:

- node lookup
- active node changes
- transition flow
- recursive navigation

This becomes the central movement system later.

NOW UPDATE gameRuntime.js

Replace the ENTIRE contents with this:

import { loadHunt } from "./loader.js";

import { Router } from "./router.js";

export class GameRuntime {
  constructor() {
    this.hunt = null;

    this.router = null;
  }

  async start(huntPath) {
    this.hunt = await loadHunt(huntPath);

    this.router = new Router(this.hunt);

    this.router.goTo(this.hunt.startNode);
  }
}
