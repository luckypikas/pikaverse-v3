### `runtime/conditions.js`

```js
import { getState } from "./stateStore.js";

export function checkConditions(
  conditions = []
) {
  const state = getState();

  return conditions.every(condition => {
    switch (condition.type) {
      case "hasItem":
        return state.inventory.includes(
          condition.item
        );

      case "hasFlag":
        return state.flags[condition.key] === true;

      default:
        console.warn(
          `Unknown condition type: ${condition.type}`
        );

        return false;
    }
  });
}
```

