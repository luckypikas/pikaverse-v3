### `runtime/effects.js`

```js
import {
  addItem,
  setFlag,
  addReward
} from "./stateStore.js";

export function runEffects(effects = []) {
  effects.forEach(effect => {
    switch (effect.type) {
      case "addItem":
        addItem(effect.item);
        break;

      case "setFlag":
        setFlag(effect.key, effect.value);
        break;

      case "addReward":
        addReward(effect.reward);
        break;

      default:
        console.warn(
          `Unknown effect type: ${effect.type}`
        );
    }
  });
}
```

