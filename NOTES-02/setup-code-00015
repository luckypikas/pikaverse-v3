### `runtime/gameRuntime.js`

```js
import { loadHunt } from "./loader.js";

import { Router } from "./router.js";

export class GameRuntime {
  constructor() {
    this.hunt = null;

    this.router = null;
  }

  async start(huntPath) {
    this.hunt = await loadHunt(huntPath);

    this.router = new Router(this.hunt);

    this.router.goTo(this.hunt.startNode);
  }
}
```

