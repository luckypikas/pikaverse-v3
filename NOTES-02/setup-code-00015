### `runtime/loader.js`

```js
export async function loadHunt(path) {
  const response = await fetch(path);

  if (!response.ok) {
    throw new Error(`Failed to load hunt: ${path}`);
  }

  const hunt = await response.json();

  validateHunt(hunt);

  return hunt;
}

function validateHunt(hunt) {
  if (!hunt.startNode) {
    throw new Error("Hunt is missing startNode");
  }

  if (!Array.isArray(hunt.nodes)) {
    throw new Error("Hunt nodes must be an array");
  }
}

export function getNodeById(hunt, nodeId) {
  return hunt.nodes.find(node => node.id === nodeId);
}
```

