# FILE: `runtime/gameRuntime.js`

Create this file and paste this EXACTLY:

```js id="vjlwm9"
import { loadHunt, getNodeById } from "./loader.js";

import {
  getState,
  setCurrentNode
} from "./stateStore.js";

import { renderNode } from "./renderer.js";

export class GameRuntime {
  constructor() {
    this.hunt = null;
  }

  async start(huntPath) {
    this.hunt = await loadHunt(huntPath);

    const startNodeId = this.hunt.startNode;

    this.goToNode(startNodeId);
  }

  goToNode(nodeId) {
    const node = getNodeById(this.hunt, nodeId);

    if (!node) {
      throw new Error(`Node not found: ${nodeId}`);
    }

    setCurrentNode(nodeId);

    renderNode(node, nextNodeId => {
      this.goToNode(nextNodeId);
    });

    console.log("Current State:", getState());
  }
}
```

