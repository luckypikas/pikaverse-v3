    "amount": 1
  }
}
```

---

### 🧠 State Changes

```json id="in3"
{
  "type": "state_update",
  "diff": {
    "inventory.ruby_key": "+1"
  }
}
```

---

### ⚠️ Validation Events

```json id="in4"
{
  "type": "validation_warning",
  "message": "Node missing optional failNodeId"
}
```

---

## 🧠 RULE

Every system emits events into ONE stream.

