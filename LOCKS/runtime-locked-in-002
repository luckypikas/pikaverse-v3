# 🧱 STEP 2 — DEPENDENCY RULE ENGINE

## `/runtime/dependencyRules.js`

```js
import { MODULE_LAYER_MAP, LAYERS } from "./architectureLayers.js";

// --------------------------------------
// ALLOWED DEPENDENCY MATRIX
// --------------------------------------
const ALLOWED = {
  [LAYERS.CORE]: [],
  [LAYERS.SYSTEMS]: [LAYERS.CORE],
  [LAYERS.EXTENSIONS]: [LAYERS.CORE, LAYERS.SYSTEMS]
};

// --------------------------------------
// CHECK RULE VIOLATION
// --------------------------------------
export function validateImport(fromModule, toModule) {
  const fromLayer = MODULE_LAYER_MAP[fromModule];
  const toLayer = MODULE_LAYER_MAP[toModule];

  if (!fromLayer || !toLayer) {
    return {
      ok: true,
      reason: "Unknown module (ignored)"
    };
  }

  const allowed = ALLOWED[fromLayer] || [];

  if (!allowed.includes(toLayer) && fromLayer !== toLayer) {
    return {
      ok: false,
      reason: `INVALID DEPENDENCY: ${fromLayer} cannot import ${toLayer}`
    };
  }

  return { ok: true };
}
```

