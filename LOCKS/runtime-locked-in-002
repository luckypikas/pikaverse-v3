# 🧱 STEP 3 — DEV-TIME GUARD (LIGHTWEIGHT ENFORCER)

## `/runtime/architectureGuard.js`

```js
import { validateImport } from "./dependencyRules.js";

const DEV_MODE = true;

// --------------------------------------
// LOG VIOLATIONS
// --------------------------------------
function reportViolation(from, to, reason) {
  console.error(
    `[ARCHITECTURE VIOLATION] ${from} → ${to}`,
    reason
  );
}

// --------------------------------------
// SAFE IMPORT WRAPPER (OPTIONAL USE)
// --------------------------------------
export function safeImport(fromModule, importFn, toModule) {
  const result = validateImport(fromModule, toModule);

  if (!result.ok) {
    if (DEV_MODE) {
      reportViolation(fromModule, toModule, result.reason);
    }

    // In dev: allow but warn
    return importFn();
  }

  return importFn();
}
```

