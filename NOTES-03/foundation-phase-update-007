import { getNodeById } from "./loader.js";
import { setCurrentNode } from "./stateStore.js";
import { renderNode } from "./renderer.js";
import { runEffects } from "./effects.js";
import { checkConditions } from "./conditions.js";
import { emit } from "./events.js";

export class Router {
  constructor(hunt) {
    this.hunt = hunt;

    // Track previous node for event emission
    this.currentNodeId = null;
  }

  goTo(nodeId) {
    const node = getNodeById(this.hunt, nodeId);

    if (!node) {
      throw new Error(`Node not found: ${nodeId}`);
    }

    // Conditions check
    if (node.conditions && !checkConditions(node.conditions)) {
      console.warn(`Conditions failed for node: ${nodeId}`);

      emit("NODE_BLOCKED", {
        attempted: nodeId,
        from: this.currentNodeId
      });

      return;
    }

    const previousNodeId = this.currentNodeId;

    // Update state
    setCurrentNode(nodeId);

    // Emit navigation event
    emit("NODE_CHANGED", {
      from: previousNodeId,
      to: nodeId
    });

    // Execute effects
    runEffects(node.effects);

    // Render node
    renderNode(node, nextNodeId => {
      this.goTo(nextNodeId);
    });

    // Update router's internal pointer
    this.currentNodeId = nodeId;
  }
}
```

