With:

```js id="dr5w0q"
const listeners = {};

export function on(event, callback) {
  if (!listeners[event]) {
    listeners[event] = [];
  }

  listeners[event].push(callback);
}

export function emit(event, payload = {}) {
  if (!listeners[event]) return;

  for (const callback of listeners[event]) {
    callback(payload);
  }
}
```

